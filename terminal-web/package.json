{
  "name": "@floegence/floeterm-terminal-web",
  "version": "0.6.6",
  "description": "Framework-neutral ghostty-web (xterm.js API-compatible) integration with terminal core, session, and data flow utilities.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floegence/floeterm.git",
    "directory": "terminal-web"
  },
  "bugs": {
    "url": "https://github.com/floegence/floeterm/issues"
  },
  "homepage": "https://github.com/floegence/floeterm#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sessions": {
      "types": "./dist/entries/sessions.d.ts",
      "import": "./dist/entries/sessions.js"
    },
    "./history": {
      "types": "./dist/entries/history.d.ts",
      "import": "./dist/entries/history.js"
    },
    "./preload": {
      "types": "./dist/entries/preload.d.ts",
      "import": "./dist/entries/preload.js"
    },
    "./live": {
      "types": "./dist/entries/live.d.ts",
      "import": "./dist/entries/live.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "dist/styles/*.css"
  ],
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && node -e \"const fs=require('fs'); if (fs.existsSync('src/styles')) fs.cpSync('src/styles', 'dist/styles', { recursive: true })\"",
    "check:package-artifact": "node scripts/check-package-artifact.mjs",
    "test": "vitest run",
    "test:browser": "node scripts/runVitestBrowser.mjs",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run test:browser && npm run build && npm run check:package-artifact"
  },
  "keywords": [
    "terminal",
    "ghostty",
    "ghostty-web",
    "pty",
    "websocket",
    "shell"
  ],
  "dependencies": {
    "@floegence/beamterm-renderer": "1.0.1",
    "ghostty-web": "0.4.0-next.14.g6a1a50d"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "jsdom": "^24.1.3",
    "playwright": "^1.57.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.16",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.8"
  }
}
